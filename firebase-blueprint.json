{
  "entities": {
    "sharedNote": {
      "title": "Shared Note",
      "description": "A note that has been shared via a unique URL",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "polishedNote": { "type": "string" },
        "tags": { "type": "array" },
        "timestamp": { "type": "number" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "polishedNote", "timestamp"]
    }
  },
  "firestore": {
    "/sharedNotes/{noteId}": {
      "schema": "sharedNote",
      "description": "Collection of shared notes"
    }
  }
}
